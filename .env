# Data Terminal Docker 环境变量示例
# 复制本文件为 .env 并按需修改

# 应用配置
APP_NAME=Data Terminal
DEBUG=false

# 数据库配置 (Docker 内使用绝对路径)
DATABASE_URL=sqlite:////app/data/data_terminal.db

# API 配置
API_V1_PREFIX=/api/v1

# 定时任务调度器
SCHEDULER_ENABLED=true

# 代理配置（如遇到 yfinance 网络限制可开启）
# PROXY_URL=socks5://host.docker.internal:1082

# 数据目录挂载路径（宿主机路径）
DATA_PATH=./data

# 前端端口映射（宿主机端口）
FRONTEND_PORT=20261
